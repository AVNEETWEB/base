<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Coming Soon Stage</title>
<style>
body{
    margin:0;overflow:hidden;height:100vh;
    background:linear-gradient(to bottom,#0f172a,#1e3a8a,#7c3aed,#f97316);
}
.coming-banner{ 
    position:absolute;left:50%;bottom:140px;transform:translateX(-50%);
    width:420px;height:100px;background:linear-gradient(135deg,#2563eb,#7c3aed,#ec4899);
    border-radius:20px;display:flex;align-items:center;justify-content:center;
    color:white;font-size:42px;font-weight:900;letter-spacing:4px;
    box-shadow:0 0 30px #7c3aed,0 0 80px #2563eb,0 0 140px #ec4899;
    animation:float 3s infinite ease-in-out; 
}
.stage-glow{position:absolute;left:50%;bottom:80px;transform:translateX(-50%);width:700px;height:200px;background:radial-gradient(circle,rgba(168,85,247,.7),transparent);filter:blur(50px);}
@keyframes float{0%,100%{transform:translateX(-50%) translateY(0)}50%{transform:translateX(-50%) translateY(-10px)}}
</style>
</head> 
<body>
<div class="stage-glow"></div>
<div class="coming-banner">🚀 BASE COMING SOON 🚀</div>
</body>
</html>
